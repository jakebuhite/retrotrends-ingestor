# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit it.

# eBay Developer credentials
# Get these from https://developer.ebay.com/my/keys
EBAY_CLIENT_ID=your-ebay-app-id
EBAY_CLIENT_SECRET=your-ebay-cert-id

# PostgreSQL connection string
# Local dev (docker compose):  postgresql://retro_user:password@localhost:5432/retrotrends
# AWS RDS:                     postgresql://user:pass@your-rds-endpoint.rds.amazonaws.com:5432/retrotrends
DATABASE_URL=postgresql://retro_user:password@localhost:5432/retrotrends

# Logging verbosity: DEBUG | INFO | WARNING
LOG_LEVEL=INFO
